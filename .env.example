# ============================================
# VIT-G-Hub OMNI - Environment Variables
# Copy this to .env.local for local dev
# ============================================

# --- Supabase (Postgres + Realtime) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Neon.tech Direct Postgres URL (for Drizzle migrations) ---
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/neondb?sslmode=require

# --- Upstash Redis (ELO Cache, Quest TTLs, Occupancy Index) ---
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- Authentication (NextAuth / Supabase Auth) ---
NEXTAUTH_SECRET=your-random-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# --- Admin Security ---
ADMIN_PASSWORD_HASH=your-bcrypt-hashed-admin-password
# Generate with: node -e "const b=require('bcryptjs');b.hash('your_password',12).then(console.log)"

# --- AI Integration (Vercel AI SDK + OpenAI) ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- Vercel Cron (Set in Vercel Dashboard as well) ---
CRON_SECRET=your-secure-random-cron-webhook-secret

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
